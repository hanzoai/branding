{
  "name": "@hanzo/branding",
  "version": "0.1.1",
  "description": "Theme engine, palette generation, and themed components for Hanzo-powered apps",
  "exports": {
    "./tg": "./src/tg/index.ts",
    "./components": "./src/tg/components/index.ts",
    "./shadcn-semantic-colors.css": "./src/shadcn-tw/shadcn-semantic-colors.css"
  },
  "bin": {
    "generate-palettes": "./dist/shadcn-tw/generate-palettes.js"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "tc": "tsc --noEmit",
    "build": "tsup src/shadcn-tw/generate-palettes.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/shadcn-tw/generate-palettes.ts --format cjs,esm --dts --watch",
    "pub": "./scripts/publish.sh"
  },
  "dependencies": {
    "@hanzo/gui": "4.3.0",
    "@hanzogui/config-default": "3.0.6",
    "@hanzogui/shorthands": "3.0.6",
    "@hanzogui/theme-builder": "3.0.6",
    "@hanzogui/web": "3.0.6"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.4",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  },
  "author": "Hanzo AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hanzoai/branding"
  },
  "publishConfig": {
    "access": "public"
  }
}
